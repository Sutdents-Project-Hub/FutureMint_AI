{
  "name": "futuremint-api",
  "version": "1.0.0",
  "description": "FutureMint AI containerized HTTP API",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "main": "dist/src/main.js",
  "scripts": {
    "build": "npm run clean && tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "evaluate:captures": "npm run build --silent && node dist/scripts/evaluateCaptures.js",
    "migrate": "npm run build --silent && node dist/scripts/migrate.js",
    "seed:postgres-demo": "npm run build --silent && node dist/scripts/seedPostgresDemo.js",
    "dev": "tsx watch src/main.ts",
    "watch": "tsc -w",
    "clean": "rimraf dist",
    "start": "node dist/src/main.js"
  },
  "dependencies": {
    "@fastify/rate-limit": "^10.3.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.10.0",
    "openai": "^6.46.0",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "22.x",
    "@types/pg": "^8.20.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.23.1",
    "typescript": "^5.0.0",
    "vitest": "^4.1.10"
  }
}
